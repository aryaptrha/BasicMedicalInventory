@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - MedInventory</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex align-items-center justify-content-center" style="background-color: var(--bg-body); min-height: 100vh; padding: 20px;">

    <div class="w-100" style="max-width: 420px;">
        <!-- Brand logo and name -->
        <div class="text-center mb-4">
            <h1 class="h3 mb-1" style="font-weight: 800; color: var(--accent-primary); letter-spacing: -0.03em;">
                <i class="bi bi-prescription2 me-2"></i>MedInventory
            </h1>
            <p class="text-secondary mb-0" style="font-size: 0.85rem;">ABC Corp Medical Inventory System Portal</p>
        </div>

        <!-- Login Card -->
        <div class="clinical-card" style="border-radius: var(--border-radius-md);">
            <h2 class="h5 mb-3" style="font-weight: 700; text-align: center;">Account Login</h2>
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger border-0 p-2 d-flex align-items-start gap-2" role="alert" style="font-size: 0.8rem; background-color: var(--status-danger-bg); color: var(--status-danger);">
                    <i class="bi bi-exclamation-octagon-fill mt-1"></i>
                    <div>
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            foreach (var error in modelState.Errors)
                            {
                                <span>@error.ErrorMessage</span><br />
                            }
                        }
                    </div>
                </div>
            }

            <form asp-controller="Auth" asp-action="Login" method="post" class="d-flex flex-column gap-3">
                <div>
                    <label class="form-label" for="loginEmail">Email Address</label>
                    <input type="email" class="form-control w-100" id="loginEmail" name="email" required placeholder="name@abc.com" />
                </div>
                
                <div>
                    <label class="form-label" for="loginPassword">Password</label>
                    <input type="password" class="form-control w-100" id="loginPassword" name="password" required placeholder="Enter your password" />
                </div>

                <button type="submit" class="btn btn-clinical w-100 mt-2" style="padding: 10px;">
                    <i class="bi bi-box-arrow-in-right"></i> Sign In
                </button>
            </form>
        </div>
    </div>

</body>
</html>
